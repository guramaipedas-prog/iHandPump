{
  "name": "ihandpump-api",
  "version": "2.0.0",
  "description": "Cloudflare Workers API untuk iHandPump Ekspedisi",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create ihandpump-db",
    "d1:migrate": "wrangler d1 migrations apply ihandpump-db",
    "d1:migrate:local": "wrangler d1 migrations apply ihandpump-db --local"
  },
  "keywords": ["cloudflare", "workers", "hono", "api"],
  "author": "guramaipedas-prog",
  "license": "MIT",
  "dependencies": {
    "hono": "^4.7.7"
  },
  "devDependencies": {
    "wrangler": "^4.92.0",
    "@cloudflare/workers-types": "^4.20250515.0"
  }
}
